# ============================================================================
# Re-Life 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ============================================================================

# ── AI 模型配置 ──────────────────────────────────────────────────────────
# 至少配置一个 AI 提供商，系统会自动选择第一个可用的

# NVIDIA API (推荐用于图像分析)
NVIDIA_API=your_nvidia_api_key_here
NVIDIA_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning

# OpenAI API
OPENAI_API=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Google Gemini API
GEMINI_API=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# DeepSeek API
DEEPSEEK_API=your_deepseek_api_key_here

# Anthropic Claude API
CLAUDE_API=your_claude_api_key_here

# 默认使用的 AI 模型 (nvidia/openai/gemini/deepseek/claude)
DEFAULT_AI_MODEL=nvidia

# ── Firebase 配置 ────────────────────────────────────────────────────────
# 用于用户认证和数据存储
# 从 Firebase Console > Project Settings > General 获取

FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789012
FIREBASE_APP_ID=1:123456789012:web:abcdef123456
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com

# ── SMTP 邮件配置 ────────────────────────────────────────────────────────
# 用于发送验证码和密码重置邮件
# 如果不配置，开发模式下会在控制台显示验证码

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Re-Life <your_email@gmail.com>

# ── SerpAPI 配置 ─────────────────────────────────────────────────────────
# 用于获取环保新闻 (可选)
# 如果不配置，会使用内置的后备新闻

SERPAPI_KEY=your_serpapi_key_here

# ── 服务器配置 ───────────────────────────────────────────────────────────
# 可选：自定义服务器设置

# SERVER_HOST=0.0.0.0
# SERVER_PORT=8000
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── 注意事项 ─────────────────────────────────────────────────────────────
# 1. 服务器端 CNN 模型位于 ./models/model_INT8.onnx
#    - 无需额外配置，服务器启动时自动加载
#    - 用于 AI 失败时的本地图像分类备份
#
# 2. Gmail SMTP 配置：
#    - 需要启用"两步验证"
#    - 使用"应用专用密码"而非账户密码
#    - 生成地址：https://myaccount.google.com/apppasswords
#
# 3. Firebase Realtime Database：
#    - 需要在 Firebase Console 启用 Realtime Database
#    - 配置规则允许读写（开发环境）
#    - 生产环境建议添加认证规则
#
# 4. AI API 费用：
#    - NVIDIA: 免费层每月 1000 次请求
#    - OpenAI: 按使用计费
#    - Gemini: 免费层每分钟 15 次请求
#    - DeepSeek: 较低成本
#    - Claude: 按使用计费
#
# 5. 开发模式：
#    - 未配置 SMTP 时，验证码会打印到控制台
#    - 未配置 Firebase 时，使用内存存储（重启丢失）
#    - 未配置任何 AI 时，只使用本地 CNN 模型
