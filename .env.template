# ============================================================================
# Re-Life 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ============================================================================

# ── AI 模型配置 ──────────────────────────────────────────────────────────
# 至少配置一个 AI 提供商，系统会自动选择第一个可用的

# NVIDIA API (推荐用于图像分析)
NVIDIA_API=your_nvidia_api_key_here
NVIDIA_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning

# OpenAI API
OPENAI_API=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Google Gemini API
GEMINI_API=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# DeepSeek API
DEEPSEEK_API=your_deepseek_api_key_here

# Anthropic Claude API
CLAUDE_API=your_claude_api_key_here

# 默认使用的 AI 模型 (nvidia/openai/gemini/deepseek/claude)
DEFAULT_AI_MODEL=nvidia

# ── Supabase configuration ──────────────────────────────────────────────
# Primary relational storage for app_users / scan_records / auth_codes / news_cache

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
SUPABASE_SECRET_KEY=your_supabase_secret_key_here
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_STORAGE_BUCKET=scan-images

# Legacy aliases used by older Python helpers
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ── Vercel KV / Upstash Redis ───────────────────────────────────────────
# Rate limiting. On Vercel this is typically provided by Upstash Redis.

UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# ── Resend 邮件配置 ───────────────────────────────────────────────────────
# 用于发送验证码和密码重置邮件
# 请在 Resend 控制台验证发送域名后再填写 RESEND_FROM
# 如果不配置 RESEND_API_KEY，开发模式下会回退到 dev_code

RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM=Re-Life <noreply@yourdomain.com>

# ── SerpAPI 配置 ─────────────────────────────────────────────────────────
# 用于获取环保新闻 (可选)
# 如果不配置，会使用内置的后备新闻

SERPAPI_KEY=your_serpapi_key_here

# ── 服务器配置 ───────────────────────────────────────────────────────────
# 可选：自定义服务器设置

# SERVER_HOST=0.0.0.0
# SERVER_PORT=8000
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── 注意事项 ─────────────────────────────────────────────────────────────
# 1. 服务器端 CNN 模型位于 ./models/model_INT8.onnx
#    - 无需额外配置，服务器启动时自动加载
#    - 用于 AI 失败时的本地图像分类备份
#
# 2. Resend 邮件配置：
#    - 发送域名需要先在 Resend 后台完成验证
#    - 生产环境建议使用自有域名作为 RESEND_FROM
#    - 参考文档：https://resend.com/docs
#
# 3. Supabase / KV:
#    - Supabase stores users, records, auth codes, and news cache
#    - Vercel KV / Upstash Redis handles request throttling
#    - Keep `SUPABASE_SECRET_KEY` / `SUPABASE_SERVICE_ROLE_KEY` on the backend only
#    - `SUPABASE_JWKS_URL` is used by JWT-validating functions
#
# 4. AI API 费用：
#    - NVIDIA: 免费层每月 1000 次请求
#    - OpenAI: 按使用计费
#    - Gemini: 免费层每分钟 15 次请求
#    - DeepSeek: 较低成本
#    - Claude: 按使用计费
#
# 5. 开发模式：
#    - 未配置 RESEND_API_KEY 时，验证码会回退到 dev_code
#    - 未配置 Supabase 时，部分数据会使用内存回退（重启丢失）
#    - 未配置任何 AI 时，只使用本地 CNN 模型
