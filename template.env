# ============================================================================
# Re-Life system environment configure
# ============================================================================

# ── AI provider config ──────────────────────────────────────────────────────────
# At least set one provider(fallback to local model if not set)

# NVIDIA API (recommended)
NVIDIA_API=your_nvidia_api_key_here
NVIDIA_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning

# OpenAI API
OPENAI_API=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Google Gemini API
GEMINI_API=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# DeepSeek API
DEEPSEEK_API=your_deepseek_api_key_here

# Anthropic Claude API
CLAUDE_API=your_claude_api_key_here

# Custom endpoint (CUSTOM_ENDPOINT_METHOD can be openai or anthropic)
# For OpenAI-compatible gateways, use the API base URL, e.g. https://host.example/v1
CUSTOM_BASE_URL=your_custom_endpoint_api_base_url
CUSTOM_API=your_api_key
CUSTOM_ENDPOINT_METHOD=openai
CUSTOM_ENDPOINT_MODEL=model_name

# Default AI provider (nvidia/openai/gemini/deepseek/claude/custom)
DEFAULT_AI_MODEL=nvidia

# ── Supabase configuration ──────────────────────────────────────────────
# Primary relational storage for app_users / scan_records / auth_codes / news_cache

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
SUPABASE_SECRET_KEY=your_supabase_secret_key_here
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_STORAGE_BUCKET=scan-images

# Legacy aliases used by older Python helpers
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ── Vercel Marketplace Redis / Upstash Redis ───────────────────────────
# Rate limiting. Vercel Marketplace Redis may provide REDIS_URL/KV_URL.
# Upstash Redis may provide KV_REST_API_URL/KV_REST_API_TOKEN or the
# UPSTASH_REDIS_REST_* names below.

REDIS_URL=rediss://default:password@your-redis-host:6379
KV_REST_API_URL=https://your-redis.upstash.io
KV_REST_API_TOKEN=your_upstash_redis_rest_token
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# ── Resend Configure ───────────────────────────────────────────────────────
# For sending verification email

RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM=Re-Life <noreply@yourdomain.com>

# ── SerpAPI Config ────────────────────────────────────────────────────────
# For fetching GreenNews

SERPAPI_KEY=your_serpapi_key_here
