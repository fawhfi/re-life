# ============================================================================
# Re-Life system environment configure
# ============================================================================

# ── AI provider config ──────────────────────────────────────────────────────────
# At least set one provider(fallback to local model if not set)

# NVIDIA API (recommended)
NVIDIA_API=your_nvidia_api_key_here
NVIDIA_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning

# OpenAI API
# OPENAI_API_KEY is the standard Agents SDK name; OPENAI_API remains supported.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ReAgent (OpenAI Agents SDK)
# Native OpenAI: keep AGENT_BASE_URL and AGENT_API_KEY blank. ReAgent will use
# OPENAI_API_KEY above with the Responses API.
AGENT_MODEL=gpt-5.6
# Optional OpenAI-compatible API root, e.g. https://host.example/v1.
# Do not include endpoint paths such as /chat/completions or /responses.
AGENT_BASE_URL=
# Required by hosted custom endpoints; local endpoints may leave this blank.
# When AGENT_BASE_URL is set, OPENAI_API_KEY is never forwarded to that host.
AGENT_API_KEY=
# auto uses Responses for native OpenAI and Chat Completions for custom endpoints.
# Explicit options: responses or chat_completions.
AGENT_API_MODE=auto
# Ephemeral user-scoped Agent session idle lifetime in seconds.
AGENT_SESSION_TTL_SECONDS=1800

# Optional fail-closed NVIDIA content-safety preflight for every new user message.
# Leave AGENT_GUARD_MODEL blank to disable the remote guard and keep local rules only.
AGENT_GUARD_MODEL=nvidia/nemotron-3.5-content-safety
AGENT_GUARD_BASE_URL=https://integrate.api.nvidia.com/v1
# Blank uses NVIDIA_API only for the official NVIDIA URL above. Custom guard
# endpoints must provide an explicit key so NVIDIA_API is never leaked to them.
AGENT_GUARD_API_KEY=
AGENT_GUARD_TIMEOUT_SECONDS=8

# Custom endpoint example (the model must support function/tool calling):
# AGENT_MODEL=qwen3:8b
# AGENT_BASE_URL=http://127.0.0.1:11434/v1
# AGENT_API_KEY=
# AGENT_API_MODE=chat_completions

# Google Gemini API
GEMINI_API=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# DeepSeek API
DEEPSEEK_API=your_deepseek_api_key_here

# Anthropic Claude API
CLAUDE_API=your_claude_api_key_here

# Custom endpoint (CUSTOM_ENDPOINT_METHOD can be openai or anthropic)
# For OpenAI-compatible gateways, use the API base URL, e.g. https://host.example/v1
CUSTOM_BASE_URL=your_custom_endpoint_api_base_url
CUSTOM_API=your_api_key
CUSTOM_ENDPOINT_METHOD=openai
CUSTOM_ENDPOINT_MODEL=model_name

# Default AI provider (nvidia/openai/gemini/deepseek/claude/custom)
DEFAULT_AI_MODEL=nvidia

# ── Session 安全設定 ────────────────────────────────────────────────────
# 此範本明確使用 production，讓 Session Cookie 僅透過 HTTPS 傳送。
APP_ENV=production
SESSION_COOKIE_NAME=rel_session
SESSION_IDLE_DAYS=30
SESSION_TOUCH_INTERVAL_SECONDS=900
SESSION_CLOCK_SKEW_SECONDS=300
# 每位使用者最多保留 1-10 個裝置 Session；資料庫硬上限固定為 10。
SESSION_MAX_PER_USER=10
# IP metadata 必須使用獨立的 HMAC 金鑰，不得重用任何 Supabase 金鑰。
# production 啟動會拒絕空白、過短或重用的金鑰；請勿保留空值部署。
# 請用密碼學安全亂數產生至少 32 字元，例如：python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_METADATA_HASH_KEY=

# ── Supabase configuration ──────────────────────────────────────────────
# Primary relational storage for app_users / scan_records / auth_codes / news_cache

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
SUPABASE_SECRET_KEY=your_supabase_secret_key_here
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_STORAGE_BUCKET=scan-images

# Legacy aliases used by older Python helpers
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ── Vercel Marketplace Redis / Upstash Redis ───────────────────────────
# 正式环境的限流必须使用持久化 Redis；未完整配置或服务故障时会拒绝认证请求。
# Vercel Marketplace Redis 可提供 REDIS_URL/KV_URL；Upstash 可提供
# KV_REST_API_URL/KV_REST_API_TOKEN，或下列 UPSTASH_REDIS_REST_* 变量。

REDIS_URL=rediss://default:password@your-redis-host:6379
KV_REST_API_URL=https://your-redis.upstash.io
KV_REST_API_TOKEN=your_upstash_redis_rest_token
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# ── Resend 电邮设置 ───────────────────────────────────────────────────────
# 用于发送注册验证与密码重设验证码。

RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM=Re-Life <noreply@yourdomain.com>

# ── 电邮验证码安全设置 ────────────────────────────────────────────────
# 正式环境必须使用至少 32 个随机字符，且不得重用 Session 或 Supabase 密钥。
AUTH_CODE_SECRET=
# 验证码有效期（秒）；默认十分钟。
VERIFICATION_CODE_EXPIRY_SECONDS=600
# 数据库约束与应用程式均限制最多五次尝试。
AUTH_CODE_MAX_ATTEMPTS=5
# 开发验证码默认关闭；只有 development 环境明确启用时才可回传。
ALLOW_DEV_AUTH_CODES=false

# ── SerpAPI Config ────────────────────────────────────────────────────────
# For fetching GreenNews

SERPAPI_KEY=your_serpapi_key_here
